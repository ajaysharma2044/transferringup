# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Stripe Configuration
STRIPE_SECRET_KEY=your_stripe_secret_key
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# Meta Ads Pixel
VITE_META_PIXEL_ID=YOUR_META_PIXEL_ID

# Salesforce Configuration
VITE_SALESFORCE_ENABLED=false

# HubSpot Configuration
VITE_HUBSPOT_PORTAL_ID=your_portal_id
VITE_HUBSPOT_FORM_GUID=your_form_guid

# Google Apps Script URL (handles Sheets logging + email notification)
VITE_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYED_SCRIPT_ID/exec

# Example:
# VITE_SUPABASE_URL=https://abcdefghijklmnop.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...